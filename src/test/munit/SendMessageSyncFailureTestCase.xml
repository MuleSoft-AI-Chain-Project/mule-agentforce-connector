<?xml version="1.0" encoding="UTF-8"?>
<mule xmlns:ms-agentforce="http://www.mulesoft.org/schema/mule/ms-agentforce"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:munit="http://www.mulesoft.org/schema/mule/munit"
      xmlns:munit-tools="http://www.mulesoft.org/schema/mule/munit-tools" xmlns="http://www.mulesoft.org/schema/mule/core"
      xmlns:doc="http://www.mulesoft.org/schema/mule/documentation" xsi:schemaLocation="
		http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
		http://www.mulesoft.org/schema/mule/munit http://www.mulesoft.org/schema/mule/munit/current/mule-munit.xsd
		http://www.mulesoft.org/schema/mule/munit-tools  http://www.mulesoft.org/schema/mule/munit-tools/current/mule-munit-tools.xsd
http://www.mulesoft.org/schema/mule/ms-agentforce http://www.mulesoft.org/schema/mule/ms-agentforce/current/mule-ms-agentforce.xsd">

    <munit:config name="SendMessageSyncFailureTestCase.xml"/>

    <!-- Commenting as this is not deterministic and is flaky
    <munit:before-test name="SendMessageSyncFailure_Before_Test" doc:id="be3f67e1-e8d7-4d88-963a-81057974c9d8" >
        <ms-agentforce:start-agent-conversation agent="${config.bot-id-failure-type}" doc:name="Start agent" doc:id="9b81ccfe-df4d-4e58-bf0a-75eec9fe3680" config-ref="Agentforce_Config_New" readTimeout="80" readTimeoutUnit="SECONDS"/>
        <set-variable value="#[output application/java&#10;-&#45;&#45;&#10;payload.sessionId]" doc:name="Set sessionId variable" doc:id="a81d4da9-331b-40fc-9cd4-e7930570d781" variableName="sessId" />
        <logger level="INFO" doc:name="Log sessionId" doc:id="301239c9-3db7-4896-84e8-3febe24636d0" message="#['Session ID: ' ++ vars.sessId]"/>
    </munit:before-test>

    &lt;!&ndash; Failure - Empty string message triggers Failure &ndash;&gt;
    <munit:test name="SendMessageSync_FailureType_EmptyString" doc:id="test-case-022" >
        <munit:execution >
            <logger level="INFO" doc:name="Log Test Start" message="Empty string message triggers Failure"/>

            <ms-agentforce:send-message-sync doc:name="Send empty string (triggers Failure)"
                                             config-ref="Agentforce_Config_New"
                                             messageSequenceNumber="1"
                                             readTimeout="80"
                                             readTimeoutUnit="SECONDS">
                <ms-agentforce:message><![CDATA[]]></ms-agentforce:message>
                <ms-agentforce:session-id><![CDATA[#[vars.sessId]]]></ms-agentforce:session-id>
            </ms-agentforce:send-message-sync>

            <logger level="INFO" doc:name="Log Response" message="#['Response - Type: ' ++ payload.messages[0].'type' ++ (if (payload.messages[0].code != null) ', Code: ' ++ payload.messages[0].code else '')]"/>
        </munit:execution>
        <munit:validation >
            &lt;!&ndash; Validate payload structure &ndash;&gt;
            <munit-tools:assert-that doc:name="Assert payload.messages exists"
                                     expression="#[payload.messages]"
                                     is="#[MunitTools::notNullValue()]"/>
            <munit-tools:assert-that doc:name="Assert has 1 message"
                                     expression="#[sizeOf(payload.messages)]"
                                     is="#[MunitTools::equalTo(1)]"/>
            <munit-tools:assert-that doc:name="Assert type is Failure"
                                     expression="#[payload.messages[0].'type']"
                                     is="#[MunitTools::equalTo('Failure')]"/>
            <munit-tools:assert-that doc:name="Assert code field exists"
                                     expression="#[payload.messages[0].code]"
                                     is="#[MunitTools::notNullValue()]"/>
            <munit-tools:assert-that doc:name="Assert errors field exists"
                                     expression="#[payload.messages[0].errors]"
                                     is="#[MunitTools::notNullValue()]"/>

            &lt;!&ndash; Validate attributes structure &ndash;&gt;
            <munit-tools:assert-that doc:name="Assert attributes exist"
                                     expression="#[attributes]"
                                     is="#[MunitTools::notNullValue()]"/>
            <munit-tools:assert-that doc:name="Assert messagesMetadata exists"
                                     expression="#[attributes.messagesMetadata]"
                                     is="#[MunitTools::notNullValue()]"/>
            <munit-tools:assert-that doc:name="Assert metadata type is Failure"
                                     expression="#[attributes.messagesMetadata[0].'type']"
                                     is="#[MunitTools::equalTo('Failure')]"/>
            <munit-tools:assert-that doc:name="Assert links exist"
                                     expression="#[attributes.links]"
                                     is="#[MunitTools::notNullValue()]"/>
        </munit:validation>
    </munit:test>

    <munit:after-test name="SendMessageSyncFailure_After_Test" doc:id="a18aeb95-427d-4bc9-816d-d68c803ed5d7" >
        <ms-agentforce:end-agent-conversation doc:name="End agent conversation" doc:id="003b5bf5-6baa-4540-9529-148e50e256ed" config-ref="Agentforce_Config_New" readTimeout="90" readTimeoutUnit="SECONDS">
            <ms-agentforce:session-id ><![CDATA[#[vars.sessId]]]></ms-agentforce:session-id>
        </ms-agentforce:end-agent-conversation>
    </munit:after-test>-->
</mule>
